# ============================================================
#  COACH RUNNING — Variables d'environnement v1.1.2
# ============================================================

# ── Strava ──────────────────────────────────────────────────
STRAVA_CLIENT_ID=COLLE_TON_CLIENT_ID_ICI
STRAVA_CLIENT_SECRET=COLLE_TON_CLIENT_SECRET_ICI

# ── Google Gemini (gratuit) ──────────────────────────────────
GEMINI_API_KEY=COLLE_TA_CLE_GEMINI_ICI

# ── Base de données (Supabase PostgreSQL direct) ─────────────
# Supabase → Settings → Database → Connection string → URI
# Format : postgresql://postgres:[MOT_DE_PASSE]@db.[PROJECT_REF].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:MOT_DE_PASSE@db.XXXX.supabase.co:5432/postgres

# ── Session ──────────────────────────────────────────────────
SESSION_SECRET=coach-running-change-moi-2024-xyz-abc

# ── URL de l'app ─────────────────────────────────────────────
APP_URL=http://localhost:3000

# ── Environnement ────────────────────────────────────────────
NODE_ENV=development
